{
  "compilerOptions": {
    "outDir": "./lib",
    "rootDir": "./",
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "target": "ES2020",
    "module": "ESNext",
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "types": ["node"]
  },
  "include": ["src/**/*"]
}